<?xml version="1.0"?>
<robot name="my_robo">

  <!-- BASE LINK-->
  <link name="base_link">
    <inertial>
      <origin xyz="0.006547 0 0.115974" rpy="0 0 0"/>
      <mass value="6.11"/>
      <inertia ixx="0.875237" ixy="0" ixz="-0.00816105"
               iyy="0.604165" iyz="0" izz="0.604008"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="1 0.5 0.3"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><box size="1 0.5 0.3"/></geometry>
      <material name="green">
        <color rgba="0 0.875 0 1"/>
      </material>
    </visual>
  </link>

  <!--WHEELS -->

  <!-- Front Left Wheel -->
  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.35 0.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="front_left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.00646" ixy="0" ixz="0"
               iyy="0.01125" iyz="0" izz="0.00646"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.1" radius="0.15"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.1" radius="0.15"/></geometry>
      <material name="dark_grey"><color rgba="0.125 0.125 0.125 1"/></material>
    </visual>
  </link>

  <!-- Front Right Wheel -->
  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="-0.35 0.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="front_right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.00646" ixy="0" ixz="0"
               iyy="0.01125" iyz="0" izz="0.00646"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.1" radius="0.15"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.1" radius="0.15"/></geometry>
      <material name="dark_grey"/>
    </visual>
  </link>

  <!-- Rear Left Wheel -->
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="0.35 -0.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="rear_left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.00646" ixy="0" ixz="0"
               iyy="0.01125" iyz="0" izz="0.00646"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.1" radius="0.15"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.1" radius="0.15"/></geometry>
      <material name="dark_grey"/>
    </visual>
  </link>

  <!-- Rear Right Wheel -->
  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.35 -0.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="rear_right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.00646" ixy="0" ixz="0"
               iyy="0.01125" iyz="0" izz="0.00646"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.1" radius="0.15"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder length="0.1" radius="0.15"/></geometry>
      <material name="dark_grey"/>
    </visual>
  </link>

  <!-- ARM -->

  <!-- Arm base (fixed to body) -->
  <joint name="arm_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base"/>
    <origin xyz="0 0 0.55" rpy="0 0 0"/>
  </joint>
  <link name="arm_base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.5" radius="0.05"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.5" radius="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Arm revolute joint -->
  <joint name="arm_to_extension" type="revolute">
    <parent link="arm_base"/>
    <child link="arm_extension"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>
  <link name="arm_extension">
    <inertial>
      <origin xyz="0.091 0 0" rpy="0 0 0"/>
      <mass value="0.55"/>
      <inertia ixx="0.01083" ixy="0" ixz="0"
               iyy="0.046270" iyz="0" izz="0.056376"/>
    </inertial>
    <collision>
      <origin xyz="0.5 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder length="1.0" radius="0.05"/></geometry>
    </collision>
    <visual>
      <origin xyz="0.5 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder length="1.0" radius="0.02"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <!--CAMERA  -->

  <joint name="camera_joint" type="fixed">
    <parent link="arm_extension"/>
    <child link="camera_link"/>

    <origin xyz="1.001 0 0" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.05 0.08 0.05"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.1 0.08 0.1"/></geometry>
      <material name="very_dark"><color rgba="0.125 0.125 0.125 1"/></material>
    </visual>
  </link>

  <!-- Camera optical frame (z forward, x right, y down — ROS convention) -->
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>
  <link name="camera_optical_frame"/>

  <!-- Gazebo camera sensor plugin -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <topic>/model/my_robo/camera</topic>
      <gz_frame_id>camera_link</gz_frame_id>
    </sensor>
  </gazebo>


  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>

    <origin xyz="0 0 0.16" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.01"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.01"/></geometry>
      <material name="light_grey"><color rgba="0.875 0.875 0.875 1"/></material>
    </visual>
  </link>

  <!-- Gazebo IMU sensor plugin -->
  <gazebo reference="imu_link">
    <sensor name="imu" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.1</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.1</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.1</stddev></noise></z>
        </linear_acceleration>
      </imu>
      <topic>/model/my_robo/imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- LIDAR -->

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>

    <origin xyz="0.4 0 0.32" rpy="0 0 0"/>
  </joint>

  <link name="lidar_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.04" radius="0.05"/></geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder length="0.04" radius="0.05"/></geometry>
      <material name="blue"><color rgba="0 0.25 1 1"/></material>
    </visual>
  </link>

  <!-- Gazebo lidar sensor plugin -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <topic>/model/my_robo/lidar</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
    </sensor>
  </gazebo>

  <!-- DIFF DRIVE PLUGIN -->
  <gazebo>
    <plugin name="ignition::gazebo::systems::DiffDrive"
            filename="libignition-gazebo-diff-drive-system.so">
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.5</wheel_separation>
      <wheel_radius>0.15</wheel_radius>
      <odom_publish_frequency>1</odom_publish_frequency>
      <odom_topic>/model/my_robo/odometry</odom_topic>
      <topic>/model/my_robo/cmd_vel</topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
    </plugin>

    <!-- Joint State Publisher plugin -->
    <plugin name="ignition::gazebo::systems::JointStatePublisher"
            filename="libignition-gazebo-joint-state-publisher-system.so">
      <joint>rear_left_wheel_joint</joint>
      <joint>rear_right_wheel_joint</joint>
      <joint>front_left_wheel_joint</joint>
      <joint>front_right_wheel_joint</joint>
      <joint>arm_to_extension</joint>
    </plugin>
  </gazebo>

</robot>
