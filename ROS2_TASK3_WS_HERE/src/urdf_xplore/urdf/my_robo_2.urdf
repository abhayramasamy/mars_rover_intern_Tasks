<?xml version="1.0"?>
<robot name="my_robo">

  <material name="grey"><color rgba="0.7 0.7 0.7 1"/></material>
  <material name="green"><color rgba="0 0.7 0 1"/></material>
  <material name="white"><color rgba="1 1 1 1"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="1.0 0.5 0.3"/>
      </geometry>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <material name="green"/>
       
    </visual>
    <collision>
      <geometry>
        <box size="1.0 0.5 0.3"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.4541" ixy="0.0" ixz="0.0" iyy="0.1875" iyz="0.0" izz="0.5667"/>
    </inertial>
  </link>

  <link name="front_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.00646" ixy="0.0" ixz="0.0" iyy="0.01125" iyz="0.0" izz="0.00646"/>
    </inertial>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.35 0.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="front_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.00646" ixy="0.0" ixz="0.0" iyy="0.01125" iyz="0.0" izz="0.00646"/>
    </inertial>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="-0.35 0.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="rear_left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.00646" ixy="0.0" ixz="0.0" iyy="0.01125" iyz="0.0" izz="0.00646"/>
    </inertial>
  </link>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="0.35 -0.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="rear_right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.00646" ixy="0.0" ixz="0.0" iyy="0.01125" iyz="0.0" izz="0.00646"/>
    </inertial>
  </link>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.35 -0.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  
  <link name="arm_base">
  	<visual>
  		<geometry>
  			<cylinder radius="0.05" length="0.5"/>
  		</geometry>
  		<origin xyz="0 0 0" rpy="0 0 0"/> 
  		<material name="white"/>
  	</visual>
  	<collision>
      <geometry>
        <cylinder radius="0.05" length="0.5"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.01073" ixy="0.0" ixz="0.0" iyy="0.000625" iyz="0.0" izz="0.01073"/>
    </inertial>
  </link>
  <joint name="arm_to_base" type="fixed">
  <parent link="base_link"/>
  <child link="arm_base"/>
  <origin xyz="0 0 0.55" rpy="0 0 0"/>
  </joint>
  
 <gazebo>
 <plugin
    filename="libignition-gazebo-diff-drive-system.so"
    name="ignition::gazebo::systems::DiffDrive">
    <left_joint>rear_left_wheel_joint</left_joint>
    <right_joint>rear_right_wheel_joint</right_joint>
    <wheel_separation>0.5</wheel_separation>
    <wheel_radius>0.15</wheel_radius>
    <odom_publish_frequency>1</odom_publish_frequency>
    <odom_topic>/model/my_robo/odometry</odom_topic>
    <topic>/model/my_robo/cmd_vel</topic>
</plugin>
</gazebo>
</robot>
