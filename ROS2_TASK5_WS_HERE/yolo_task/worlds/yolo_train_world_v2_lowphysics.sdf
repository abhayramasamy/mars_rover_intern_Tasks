<sdf version='1.9'>
  <world name='empty'>
    <physics name='1ms' type='ignored'>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- World plugins here book  marked-->
    <plugin name='gz::sim::systems::Physics'          filename='ignition-gazebo-physics-system'/>
    <plugin name='gz::sim::systems::UserCommands'     filename='ignition-gazebo-user-commands-system'/>
    <plugin name='gz::sim::systems::SceneBroadcaster' filename='ignition-gazebo-scene-broadcaster-system'/>
    <plugin name='gz::sim::systems::Contact'          filename='ignition-gazebo-contact-system'/>
    <plugin name='gz::sim::systems::Sensors' filename='ignition-gazebo-sensors-system'>
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin name='gz::sim::systems::Imu'     filename='ignition-gazebo-imu-system'/>

    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type='adiabatic'/>
    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>true</shadows>
    </scene>

    <!--ground plane book mark-->
    <model name='ground_plane'>
      <static>true</static>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <surface>
            <friction><ode/></friction>
            <bounce/>
            <contact/>
          </surface>
        </collision>
        <visual name='visual'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
        <pose>0 0 0 0 -0 0</pose>
        <inertial>
          <pose>0 0 0 0 -0 0</pose>
          <mass>1</mass>
          <inertia>
            <ixx>1</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>1</iyy><iyz>0</iyz><izz>1</izz>
          </inertia>
        </inertial>
        <enable_wind>false</enable_wind>
      </link>
      <pose>0 0 0 0 -0 0</pose>
      <self_collide>false</self_collide>
    </model>

    <!-- ==#=#+##33=3=3-3= MY_ROBO ##########333 -->
    <model name='my_robo'>

      <!--  BASE LINK -->
      <link name='base_link'>
        <inertial>
          <pose>0.006547 0 0.115974 0 -0 0</pose>
          <mass>6.1100000000000003</mass>
          <inertia>
            <ixx>0.87523700000000004</ixx><ixy>0</ixy><ixz>-0.0081610499999999996</ixz>
            <iyy>0.60416499999999995</iyy><iyz>0</iyz><izz>0.60400799999999999</izz>
          </inertia>
        </inertial>

        <!-- Collisions -->
        <collision name='base_link_collision'>
          <pose>0 0 0 0 0 0</pose>
          <geometry><box><size>1 0.5 0.3</size></box></geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <collision name='base_link_fixed_joint_lump__arm_base_collision_1'>
          <pose>0 0 0.55 0 0 0</pose>
          <geometry><cylinder><length>0.5</length><radius>0.050000000000000003</radius></cylinder></geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <collision name='base_link_fixed_joint_lump__arm_joint_cylinder_collision_2'>
          <pose>0 0 0.8 0 0 0</pose>
          <geometry><cylinder><length>0.5</length><radius>0.050000000000000003</radius></cylinder></geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <collision name='base_link_fixed_joint_lump__imu_link_collision_3'>
          <pose>0 0 0.16 0 0 0</pose>
          <geometry><box><size>0.03 0.03 0.01</size></box></geometry>
          <surface><contact><ode/></contact><friction><ode/></friction><bounce/></surface>
        </collision>
        <collision name='base_link_fixed_joint_lump__lidar_link_collision_4'>
          <pose>0.4 0 0.32 0 0 0</pose>
          <geometry><cylinder><length>0.040000000000000001</length><radius>0.050000000000000003</radius></cylinder></geometry>
          <surface><contact><ode/></contact><friction><ode/></friction><bounce/></surface>
        </collision>

        <!-- Visuals -->
        <visual name='base_link_visual'>
          <pose>0 0 0.15 0 0 0</pose>
          <geometry><box><size>1 0.5 0.3</size></box></geometry>
          <material><diffuse>0 0.875 0 1</diffuse><ambient>0 0.875 0 1</ambient></material>
        </visual>
        <visual name='base_link_fixed_joint_lump__arm_base_visual_1'>
          <pose>0 0 0.55 0 0 0</pose>
          <geometry><cylinder><length>0.5</length><radius>0.050000000000000003</radius></cylinder></geometry>
          <material><diffuse>1 1 1 1</diffuse><ambient>1 1 1 1</ambient></material>
        </visual>
        <visual name='base_link_fixed_joint_lump__arm_joint_cylinder_visual_2'>
          <pose>0 0 0.8 0 1.570796326794897 -1.570796326794897</pose>
          <geometry><cylinder><length>0.20000000000000001</length><radius>0.059999999999999998</radius></cylinder></geometry>
          <material><diffuse>1 1 1 1</diffuse><ambient>1 1 1 1</ambient></material>
        </visual>
        <visual name='base_link_fixed_joint_lump__imu_link_visual_3'>
          <pose>0 0 0.16 0 0 0</pose>
          <geometry><box><size>0.03 0.03 0.01</size></box></geometry>
          <material><diffuse>0.875 0.875 0.875 1</diffuse><ambient>0.875 0.875 0.875 1</ambient></material>
        </visual>
        <visual name='base_link_fixed_joint_lump__lidar_link_visual_4'>
          <pose>0.4 0 0.32 0 0 0</pose>
          <geometry><cylinder><length>0.040000000000000001</length><radius>0.050000000000000003</radius></cylinder></geometry>
          <material><diffuse>0 0.25 1 1</diffuse><ambient>0 0.25 1 1</ambient></material>
        </visual>

        <sensor name='imu' type='imu'>
          <pose>0 0 0.31 0 0 0</pose>
          <topic>/model/my_robo/imu</topic>
          <update_rate>100</update_rate>
          <imu>
            <angular_velocity>
              <x><noise type='gaussian'><mean>0</mean><stddev>0.001</stddev></noise></x>
              <y><noise type='gaussian'><mean>0</mean><stddev>0.001</stddev></noise></y>
              <z><noise type='gaussian'><mean>0</mean><stddev>0.001</stddev></noise></z>
            </angular_velocity>
            <linear_acceleration>
              <x><noise type='gaussian'><mean>0</mean><stddev>0.01</stddev></noise></x>
              <y><noise type='gaussian'><mean>0</mean><stddev>0.01</stddev></noise></y>
              <z><noise type='gaussian'><mean>0</mean><stddev>0.01</stddev></noise></z>
            </linear_acceleration>
          </imu>
          <always_on>1</always_on>
          <visualize>true</visualize>
        </sensor>

        <sensor name='lidar' type='gpu_lidar'>
          <pose>0.4 0 0.47 0 0 0</pose>
          <topic>/model/my_robo/lidar</topic>
          <update_rate>10</update_rate>
          <ray>
            <scan>
              <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
              </horizontal>
            </scan>
            <range>
              <min>0.15</min>
              <max>12.0</max>
              <resolution>0.01</resolution>
            </range>
            <noise>
              <type>gaussian</type>
              <mean>0.0</mean>
              <stddev>0.01</stddev>
            </noise>
          </ray>
          <always_on>1</always_on>
          <visualize>true</visualize>

          <frame_id>lidar_link</frame_id>
        </sensor>
        <!-- front facing camera on base link --> 
        <sensor name='front_camera' type='camera'>
  <pose>0.51 0 0.3 0 0 0</pose>
  <topic>/model/my_robo/front_camera</topic>
  <update_rate>30</update_rate>
  <camera>
    <horizontal_fov>1.047</horizontal_fov>
    <image>
      <width>640</width>
      <height>480</height>
      <format>R8G8B8</format>
    </image>
    <clip>
      <near>0.1</near>
      <far>100</far>
    </clip>
    <noise>
      <type>gaussian</type>
      <mean>0.0</mean>
      <stddev>0.007</stddev>
    </noise>
  </camera>
  <always_on>1</always_on>
  <visualize>true</visualize>
  <frame_id>front_camera_link</frame_id>
</sensor>

        <pose>0 0 0 0 -0 0</pose>
        <enable_wind>false</enable_wind>
      </link>

      <!--  ARM JOINT  -->
      <joint name='arm_to_extension' type='revolute'>
        <pose>0 0 0 0 -0 0</pose>
        <parent>base_link</parent>
        <child>arm_extension</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-1.5700000000000001</lower>
            <upper>1.5700000000000001</upper>
            <effort>10</effort>
            <velocity>1</velocity>
            <stiffness>100000000</stiffness>
            <dissipation>1</dissipation>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference>
            <spring_stiffness>0</spring_stiffness>
            <damping>0</damping>
            <friction>0</friction>
          </dynamics>
        </axis>
      </joint>

      <!--  ARM EXTENSION LINK  -->
      <link name='arm_extension'>
        <pose>0 0 0.8 0 -0 0</pose>
        <inertial>
          <pose>0.091 0 0 0 -0 0</pose>
          <mass>0.55000000000000004</mass>
          <inertia>
            <ixx>0.010829999999999999</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.046270499999999999</iyy><iyz>0</iyz><izz>0.056375500000000002</izz>
          </inertia>
        </inertial>
        <collision name='arm_extension_collision'>
          <pose>0 0 0 0 0 0</pose>
          <geometry><cylinder><length>1</length><radius>0.050000000000000003</radius></cylinder></geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <collision name='arm_extension_fixed_joint_lump__camera_link_collision_1'>
          <pose>1.001 0 0 0 0 0</pose>
          <geometry><box><size>0.05 0.08 0.05</size></box></geometry>
          <surface><contact><ode/></contact><friction><ode/></friction><bounce/></surface>
        </collision>
        <visual name='arm_extension_visual'>
          <pose>0.5 0 0 0 1.570796326794897 0</pose>
          <geometry><cylinder><length>1</length><radius>0.02</radius></cylinder></geometry>
          <material><diffuse>1 1 1 1</diffuse><ambient>1 1 1 1</ambient></material>
        </visual>
        <visual name='arm_extension_fixed_joint_lump__camera_link_visual_1'>
          <pose>1.001 0 0 0 0 0</pose>
          <geometry><box><size>0.1 0.08 0.1</size></box></geometry>
          <material><diffuse>0.125 0.125 0.125 1</diffuse><ambient>0.125 0.125 0.125 1</ambient></material>
        </visual>

        <sensor name='camera' type='camera'>
          <pose>1.001 0 0.95 0 0 0</pose>
          <topic>/model/my_robo/camera</topic>
          <update_rate>30</update_rate>
          <camera>
            <horizontal_fov>1.047</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.1</near>
              <far>100</far>
            </clip>
            <noise>
              <type>gaussian</type>
              <mean>0.0</mean>
              <stddev>0.007</stddev>
            </noise>
          </camera>
          <always_on>1</always_on>
          <visualize>true</visualize>
          <!-- frame_id for the gz→ROS bridge -->
          <frame_id>camera_link</frame_id>
        </sensor>

        <enable_wind>false</enable_wind>
      </link>

      <!--  WHEEL JOINTS & LINKS-->

      <joint name='front_left_wheel_joint' type='revolute'>
        <pose>0 0 0 0 -0 0</pose>
        <parent>base_link</parent>
        <child>front_left_wheel</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-10000000000000000</lower><upper>10000000000000000</upper>
            <effort>inf</effort><velocity>inf</velocity>
            <stiffness>100000000</stiffness><dissipation>1</dissipation>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness>
            <damping>0</damping><friction>0</friction>
          </dynamics>
        </axis>
      </joint>
      <link name='front_left_wheel'>
        <pose>0.35 0.3 0 0 -0 0</pose>
        <inertial>
          <pose>0 0 0 1.5708 -0 0</pose>
          <mass>1</mass>
          <inertia>
            <ixx>0.0064599999999999996</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.01125</iyy><iyz>0</iyz><izz>0.0064599999999999996</izz>
          </inertia>
        </inertial> <!--tags added here-->
        <surface>
  <friction>
    <ode>
      <mu>0.05</mu>
      <mu2>0.05</mu2>
      <slip1>1.0</slip1>
      <slip2>1.0</slip2>
    </ode>
  </friction>
</surface>
        <collision name='front_left_wheel_collision'>
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><length>0.10000000000000001</length><radius>0.14999999999999999</radius></cylinder></geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <visual name='front_left_wheel_visual'>
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><length>0.10000000000000001</length><radius>0.14999999999999999</radius></cylinder></geometry>
          <material><diffuse>0.125 0.125 0.125 1</diffuse><ambient>0.125 0.125 0.125 1</ambient></material>
        </visual>
        <enable_wind>false</enable_wind>
      </link>

      <joint name='front_right_wheel_joint' type='revolute'>
        <pose>0 0 0 0 -0 0</pose>
        <parent>base_link</parent>
        <child>front_right_wheel</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-10000000000000000</lower><upper>10000000000000000</upper>
            <effort>inf</effort><velocity>inf</velocity>
            <stiffness>100000000</stiffness><dissipation>1</dissipation>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness>
            <damping>0</damping><friction>0</friction>
          </dynamics>
        </axis>
      </joint>
      <link name='front_right_wheel'>
        <pose>-0.35 0.3 0 0 -0 0</pose>
        <inertial>
          <pose>0 0 0 1.5708 -0 0</pose>
          <mass>1</mass>
          <inertia>
            <ixx>0.0064599999999999996</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.01125</iyy><iyz>0</iyz><izz>0.0064599999999999996</izz>
          </inertia>
        </inertial>  <!--tags here-->
        <surface>
  <friction>
    <ode>
      <mu>0.05</mu>
      <mu2>0.05</mu2>
      <slip1>1.0</slip1>
      <slip2>1.0</slip2>
    </ode>
  </friction>
</surface>
        <collision name='front_right_wheel_collision'>
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><length>0.10000000000000001</length><radius>0.14999999999999999</radius></cylinder></geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <visual name='front_right_wheel_visual'>
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><length>0.10000000000000001</length><radius>0.14999999999999999</radius></cylinder></geometry>
          <material><diffuse>0.125 0.125 0.125 1</diffuse><ambient>0.125 0.125 0.125 1</ambient></material>
        </visual>
        <enable_wind>false</enable_wind>
      </link>

      <joint name='rear_left_wheel_joint' type='revolute'>
        <pose>0 0 0 0 -0 0</pose>
        <parent>base_link</parent>
        <child>rear_left_wheel</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-10000000000000000</lower><upper>10000000000000000</upper>
            <effort>inf</effort><velocity>inf</velocity>
            <stiffness>100000000</stiffness><dissipation>1</dissipation>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness>
            <damping>0</damping><friction>0</friction>
          </dynamics>
        </axis>
      </joint>
      <link name='rear_left_wheel'>
        <pose>0.35 -0.3 0 0 -0 0</pose>
        <inertial>
          <pose>0 0 0 1.5708 -0 0</pose>
          <mass>1</mass>
          <inertia>
            <ixx>0.0064599999999999996</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.01125</iyy><iyz>0</iyz><izz>0.0064599999999999996</izz>
          </inertia>
        </inertial>
        <!--tags added here-->
        <surface>
  <friction>
    <ode>
      <mu>1.0</mu>
      <mu2>0.3</mu2>
      <slip1>0.0</slip1>
      <slip2>0.2</slip2>
    </ode>
  </friction>
</surface>
        <collision name='rear_left_wheel_collision'>
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><length>0.10000000000000001</length><radius>0.14999999999999999</radius></cylinder></geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <visual name='rear_left_wheel_visual'>
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><length>0.10000000000000001</length><radius>0.14999999999999999</radius></cylinder></geometry>
          <material><diffuse>0.125 0.125 0.125 1</diffuse><ambient>0.125 0.125 0.125 1</ambient></material>
        </visual>
        <enable_wind>false</enable_wind>
      </link>

      <joint name='rear_right_wheel_joint' type='revolute'>
        <pose>0 0 0 0 -0 0</pose>
        <parent>base_link</parent>
        <child>rear_right_wheel</child>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-10000000000000000</lower><upper>10000000000000000</upper>
            <effort>inf</effort><velocity>inf</velocity>
            <stiffness>100000000</stiffness><dissipation>1</dissipation>
          </limit>
          <dynamics>
            <spring_reference>0</spring_reference><spring_stiffness>0</spring_stiffness>
            <damping>0</damping><friction>0</friction>
          </dynamics>
        </axis>
      </joint>
      <link name='rear_right_wheel'>
        <pose>-0.35 -0.3 0 0 -0 0</pose>
        <inertial>
          <pose>0 0 0 1.5708 -0 0</pose>
          <mass>1</mass>
          <inertia>
            <ixx>0.0064599999999999996</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.01125</iyy><iyz>0</iyz><izz>0.0064599999999999996</izz>
          </inertia>
        </inertial>
        <!--tags added here-->
        <surface>
  <friction>
    <ode>
      <mu>1.0</mu>
      <mu2>0.3</mu2>
      <slip1>0.0</slip1>
      <slip2>0.2</slip2>
    </ode>
  </friction>
</surface>
        <collision name='rear_right_wheel_collision'>
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><length>0.10000000000000001</length><radius>0.14999999999999999</radius></cylinder></geometry>
          <surface><friction><ode/></friction><bounce/><contact/></surface>
        </collision>
        <visual name='rear_right_wheel_visual'>
          <pose>0 0 0 1.5708 0 0</pose>
          <geometry><cylinder><length>0.10000000000000001</length><radius>0.14999999999999999</radius></cylinder></geometry>
          <material><diffuse>0.125 0.125 0.125 1</diffuse><ambient>0.125 0.125 0.125 1</ambient></material>
        </visual>
        <enable_wind>false</enable_wind>
      </link>

      <!-- MODEL-LEVEL PLUGINS -->
      <plugin name='ignition::gazebo::systems::DiffDrive' filename='libignition-gazebo-diff-drive-system.so'>
        <left_joint>rear_left_wheel_joint</left_joint>
        <right_joint>rear_right_wheel_joint</right_joint>
        <wheel_separation>0.5</wheel_separation>
        <wheel_radius>0.15</wheel_radius>
        <odom_publish_frequency>1</odom_publish_frequency>
        <odom_topic>/model/my_robo/odometry</odom_topic>
        <topic>/model/my_robo/cmd_vel</topic>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>
      </plugin>

      <plugin name='ignition::gazebo::systems::JointStatePublisher' filename='libignition-gazebo-joint-state-publisher-system.so'>
        <joint>rear_left_wheel_joint</joint>
        <joint>rear_right_wheel_joint</joint>
        <joint>front_left_wheel_joint</joint>
        <joint>front_right_wheel_joint</joint>
        <joint>arm_to_extension</joint>
      </plugin>
<!--added a new plugin over here-->
<plugin filename="gz_ros2_control-system"
        name="gz_ros2_control::GazeboSimROS2ControlPlugin">
  <robot_param>robot_description</robot_param>
  <robot_param_node>robot_state_publisher</robot_param_node>
  <parameters>/home/abhay-07/arm_controllers.yaml</parameters>
</plugin>

      <!-- FRAMES (unchanged from original) -->
      <frame name='arm_to_extension_cylinder' attached_to='arm_base'>
        <pose>0 0 0.25 0 -0 0</pose>
      </frame>
      <frame name='arm_joint_cylinder' attached_to='arm_to_extension_cylinder'/>
      <frame name='arm_to_base' attached_to='base_link'>
        <pose>0 0 0.55 0 -0 0</pose>
      </frame>
      <frame name='arm_base' attached_to='arm_to_base'/>
      <frame name='end_effector_to_ae' attached_to='arm_extension'>
        <pose>1.001 0 0 0 -0 0</pose>
      </frame>
      <frame name='camera_link' attached_to='end_effector_to_ae'/>
      <frame name='imu_joint' attached_to='base_link'>
        <pose>0 0 0.16 0 -0 0</pose>
      </frame>
      <frame name='imu_link' attached_to='imu_joint'/>
      <frame name='lidar_joint' attached_to='base_link'>
        <pose>0.4 0 0.32 0 -0 0</pose>
      </frame>
